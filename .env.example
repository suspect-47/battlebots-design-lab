# ─── Alibaba Cloud Model Studio (DashScope) ────────────────────────────────────
# The LLM behind every agent in this project: the five design specialists, the
# fight analyst, and Freya. Get a key at https://www.qwencloud.com (Model Studio
# → API keys). Server-side only — it never reaches the browser.
DASHSCOPE_API_KEY=
# International endpoint (default). Mainland China:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# qwen-plus (default) | qwen-max | qwen-turbo
QWEN_MODEL=qwen-plus

# ─── Data spine ────────────────────────────────────────────────────────────────
# Postgres connection for the fight-data spine (optional: the app runs from a
# committed snapshot without it)
DATABASE_URL=postgres://localhost:5432/battlebots
# Bright Data — set for a live scrape refresh; the committed dataset is used otherwise
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=

# ─── Frontend ──────────────────────────────────────────────────────────────────
# Frontend → backend base URL. Point this at your Alibaba Cloud Function Compute
# HTTP trigger (or ECS host) once deployed. Default http://localhost:3001
VITE_API_BASE=
